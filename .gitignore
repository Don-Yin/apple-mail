# Python bytecode
__pycache__/
*.pyc

# Runtime state — generated by the skill, never commit
assets/index.db
assets/index.db-wal
assets/index.db-shm
assets/index-progress.json
assets/index-progress.lock
assets/logs/
assets/.deps.hash
assets/deletion-log.jsonl
assets/index*.db
assets/index*.db-*
assets/**/index*.db
assets/**/index*.db-*
assets/corrupt-index-backup-*/
scripts/lib/search_index/*.db

# Keep the assets directory itself
!assets/.gitkeep

# Local editor/agent state; .cursor may be a symlink outside this repo.
.cursor
.cursor/
agents/

# Local/experimental online sync backend. Keep out of the public skill until
# it has a separate security and university-account review.
scripts/lib/ops/imap_sync.py
